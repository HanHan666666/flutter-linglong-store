# Maintainer: @MAINTAINER_NAME@ <@MAINTAINER_EMAIL@>
pkgname=@AUR_PKGNAME@
pkgver=@AUR_PKGVER@
pkgrel=1
pkgdesc="Community store for browsing and installing Linglong applications"
arch=(@AUR_ARCH_VALUES@)
url="@PROJECT_URL@"
license=('MIT')
depends=(
  'atk'
  'bash'
  'cairo'
  'fontconfig'
  'gdk-pixbuf2'
  'glib2'
  'gtk3'
  'libstdc++'
  'hicolor-icon-theme'
  'libepoxy'
  'pango'
)
optdepends=(
  'linglong: Linglong runtime environment for installing and launching apps'
)
provides=(@AUR_PROVIDES_VALUES@)
conflicts=(@AUR_CONFLICTS_VALUES@)
changelog=@AUR_CHANGELOG_FILENAME@

# PGP signature verification
validpgpkeys=('@GPG_KEY_ID@')

source=(
  'LICENSE'
  '@DESKTOP_FILENAME@'
  'linglong-store.metainfo.xml'
  'linglong-store.svg'
)
source_x86_64=(
  "linglong-store-@AUR_SOURCE_VERSION@-linux-amd64.tar.gz::@RELEASE_URL_BASE@/@AUR_SOURCE_TAG_ROOT@/linglong-store-@AUR_SOURCE_VERSION@-linux-amd64.tar.gz"
  "linglong-store-@AUR_SOURCE_VERSION@-linux-amd64.tar.gz.asc::@RELEASE_URL_BASE@/@AUR_SOURCE_TAG_ROOT@/linglong-store-@AUR_SOURCE_VERSION@-linux-amd64.tar.gz.asc"
)
@AUR_SOURCE_AARCH64_BLOCK@

sha256sums=(
  '@SHA256_LICENSE@'
  '@SHA256_DESKTOP@'
  '@SHA256_METAINFO@'
  '@SHA256_ICON@'
)
sha256sums_x86_64=(
  '@SHA256_AMD64@'
  '@SHA256_SIG_AMD64@'
)
@AUR_SHA256SUMS_AARCH64_BLOCK@

package() {
  # Install application files
  install -dm755 "${pkgdir}/opt/linglong-store"
  cp -a "${srcdir}/linglong-store/." "${pkgdir}/opt/linglong-store/"

  # Install launcher script
  install -dm755 "${pkgdir}/usr/bin"
  cat > "${pkgdir}/usr/bin/linglong-store" <<'LAUNCHER'
#!/usr/bin/bash
set -euo pipefail
exec /opt/linglong-store/linglong_store "$@"
LAUNCHER
  chmod 755 "${pkgdir}/usr/bin/linglong-store"

  # Install desktop metadata from tracked AUR sources so package metadata
  # does not depend on optional files inside the release tarball.
  install -Dm644 "${srcdir}/@DESKTOP_FILENAME@" "${pkgdir}/usr/share/applications/@DESKTOP_FILENAME@"

  # Validate desktop file if tool available
  if command -v desktop-file-validate &>/dev/null; then
    desktop-file-validate "${pkgdir}/usr/share/applications/@DESKTOP_FILENAME@" || true
  fi

  # Install icon
  install -Dm644 "${srcdir}/linglong-store.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/linglong-store.svg"

  # Install metainfo
  install -Dm644 "${srcdir}/linglong-store.metainfo.xml" "${pkgdir}/usr/share/metainfo/linglong-store.metainfo.xml"

  # Install LICENSE
  install -Dm644 "${srcdir}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
